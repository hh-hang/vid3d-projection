{
  "name": "three-video-projection",
  "version": "0.1.0",
  "description": "Projector utility for projecting video textures onto meshes (three.js)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "three",
    "videoProjection",
    "videoFusion"
  ],
  "author": "hh-hang",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "prepare": "npm run build",
    "build:example": "vite build && node -e \"require('fs').writeFileSync('docs/.nojekyll', '')\""
  },
  "peerDependencies": {
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "hls.js": "^1.6.15",
    "sass-embedded": "^1.98.0",
    "stats.js": "^0.17.0",
    "three-player-controller": "^0.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vue": "^3.5.27"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hh-hang/three-video-projection"
  },
  "homepage": "https://hh-hang.github.io/three-video-projection/"
}
